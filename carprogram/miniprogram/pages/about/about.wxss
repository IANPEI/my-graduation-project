.about-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}

.about-header {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.about-content {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
}

.about-item {
  margin-bottom: 40rpx;
}

.about-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.value {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}