<view class="container">
  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 统一LOGO -->
    <view class="logo">🚗 汽车救援服务平台</view>

    <!-- 账号输入 -->
    <view class="input-item">
      <text class="label">登录账号</text>
      <input 
        placeholder="请输入手机号/服务商账号" 
        bindinput="onAccountInput" 
        value="{{account}}"
      />
    </view>

    <!-- 密码输入 -->
    <view class="input-item">
      <text class="label">登录密码</text>
      <input 
        type="password" 
        placeholder="请输入登录密码" 
        bindinput="onPwdInput" 
        value="{{password}}"
      />
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn" bindtap="login" wx:if="{{!loading}}">登录</view>
    <view class="login-btn loading" wx:else>登录中...</view>
    <!-- 注册入口 -->
    <view class="register-btn" bindtap="goRegister">没有账号？立即注册</view>
    <!-- 身份提示（辅助说明） -->
    <text class="aux-tip">系统将自动识别您的身份，跳转到对应功能页面</text>
  </view>
</view>