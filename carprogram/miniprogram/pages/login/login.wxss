/* 全局容器：居中+灰色背景 */
.container {
  padding: 40rpx 20rpx;
  display: flex;
  justify-content: center;
  background-color: #F5F5F7;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 登录卡片：白色背景+轻微阴影 */
.login-card {
  width: 100%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}

/* LOGO样式：居中+大号字体 */
.logo {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 60rpx;
}

/* 输入项通用样式 */
.input-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  background-color: #F9F9F9;
}

/* 验证码行：左右布局 */
.verify-code {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.get-code-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #EEEEEE;
  color: #666666;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  padding: 0;
}

/* 登录按钮：救援红+圆角 */
.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #F53F3F;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

/* 加载中样式：弱化背景 */
.login-btn.loading {
  background-color: #F86666;
  color: #FFFFFF;
}

/* 辅助提示文字：浅灰+小号 */
.aux-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 30rpx;
}

/* 注册按钮样式 */
.register-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #ffffff;
  color: #F53F3F;
  font-size: 30rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  border: 1rpx solid #F53F3F;
}