<view class="container">
  <view class="register-card">
    <view class="logo">🚗 账号注册</view>

    <!-- 身份选择 -->
    <view class="role-group">
      <view class="role-item {{role==='owner'?'active':''}}" bindtap="selectRole" data-role="owner">
        车主用户
      </view>
      <view class="role-item {{role==='supplier'?'active':''}}" bindtap="selectRole" data-role="supplier">
        服务商
      </view>
    </view>

    <!-- 通用信息 -->
    <view class="input-item">
      <text class="label">手机号（登录账号）</text>
      <input placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
    </view>

    <view class="input-item">
      <text class="label">昵称</text>
      <input placeholder="请输入昵称" bindinput="onNicknameInput" value="{{nickname}}" />
    </view>

    <view class="input-item">
      <text class="label">登录密码</text>
      <input type="password" placeholder="请设置密码" bindinput="onPwdInput" value="{{password}}" />
    </view>

    <!-- 服务商额外信息 -->
    <view wx:if="{{role==='supplier'}}">
      <view class="input-item">
        <text class="label">服务商名称</text>
        <input placeholder="请输入服务商名称" bindinput="onSupplierNameInput" value="{{supplierName}}" />
      </view>
      <view class="input-item">
        <text class="label">联系人</text>
        <input placeholder="请输入联系人" bindinput="onContactInput" value="{{contact}}" />
      </view>
      <view class="input-item">
        <text class="label">所在城市</text>
        <input placeholder="如：北京市" bindinput="onCityInput" value="{{city}}" />
      </view>
      <view class="input-item">
        <text class="label">详细地址</text>
        <input placeholder="请输入详细地址" bindinput="onAddressInput" value="{{address}}" />
      </view>
    </view>

    <!-- 注册按钮 -->
    <view class="register-btn" bindtap="doRegister" wx:if="{{!loading}}">立即注册</view>
    <view class="register-btn loading" wx:else>注册中...</view>
  </view>
</view>