/* 全局容器 */
.order-container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #fff;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 15px 0;
  font-size: 15px;
  color: #666;
  position: relative;
}

.filter-item.active {
  color: #409eff;
  font-weight: 600;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30px;
  height: 2px;
  background-color: #409eff;
}

/* 订单列表 */
.order-list {
  padding: 15px;
  display: flex;
  flex-direction: column;
  gap: 15px;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 1px solid #eee;
}

.order-no {
  font-size: 14px;
  color: #333;
}

.order-status {
  font-size: 14px;
  font-weight: 600;
}

/* 订单信息 */
.order-info {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 15px;
}

.info-item {
  display: flex;
  font-size: 14px;
}

.label {
  color: #999;
  min-width: 80px;
}

.value {
  color: #666;
  flex: 1;
  word-break: break-all;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
}

.accept-btn {
  background-color: #409eff;
  color: #fff;
  border: none;
  border-radius: 4px;
  padding: 8px 16px;
  font-size: 14px;
}

.complete-btn {
  background-color: #67c23a;
  color: #fff;
  border: none;
  border-radius: 4px;
  padding: 8px 16px;
  font-size: 14px;
}

/* 空数据提示 */
.empty-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200px;
  font-size: 15px;
  color: #999;
}

page {
  background-color: #f5f5f5;
}

/* 弹窗遮罩 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}
.staff-list {
  max-height: 500rpx;
}
.staff-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
}
.staff-item.active {
  background: #e6f7ff;
  border-color: #1890ff;
}
.phone {
  color: #666;
  font-size: 26rpx;
}
.modal-btns {
  display: flex;
  justify-content: flex-end;
  margin-top: 30rpx;
  gap: 20rpx;
}
.cancel {
  background: #f5f5f5;
  color: #666;
}
.confirm {
  background: #1890ff;
  color: #fff;
}

/* 取消订单按钮 */
.cancel-btn {
  background-color: #F53F3F;
  color: #fff;
  border: none;
  border-radius: 4px;
  padding: 8px 16px;
  font-size: 14px;
  margin-right: 10px;
}