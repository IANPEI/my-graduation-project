<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <view class="card" wx:if="{{!loading && orderDetail.status === 'processing'}}">
  <text class="title">服务商实时位置</text>
  <view class="divider"></view>
  <map
    id="map"
    longitude="{{lng}}"
    latitude="{{lat}}"
    markers="{{markers}}"
    style="width:100%;height:280px;border-radius:8px;"
    scale="16"
  ></map>
</view>

  <!-- 订单基本信息 -->
  <view class="card" wx:else>
    <view class="row-between">
      <text class="title">订单详情</text>
      <text class="order-status {{orderDetail.status}}">{{orderDetail.statusText}}</text>
    </view>
    <view class="divider"></view>
    <view class="detail-item">
      <text class="aux-text">订单号：</text>
      <text>{{orderDetail.orderNo}}</text>
    </view>
    <view class="detail-item">
      <text class="aux-text">创建时间：</text>
      <text>{{orderDetail.createTimeText}}</text>
    </view>
    <view class="detail-item">
      <text class="aux-text">故障类型：</text>
      <text>{{orderDetail.faultTypeName}}</text>
    </view>
  </view>

  <!-- 救援信息（新增救援公司） -->
  <view class="card" wx:if="{{!loading}}">
    <text class="title">救援信息</text>
    <view class="divider"></view>
    <view class="detail-item">
      <text class="aux-text">救援地址：</text>
      <text>{{orderDetail.address}}</text>
    </view>
    <view class="detail-item">
      <text class="aux-text">补充说明：</text>
      <text>{{orderDetail.remark || '无'}}</text>
    </view>
    <!-- 救援公司 -->
    <view class="detail-item">
      <text class="aux-text">救援公司：</text>
      <text>{{orderDetail.supplierName || '暂无'}}</text>
    </view>
    <!-- 维修师傅 -->
    <view class="detail-item" wx:if="{{orderDetail.staffName}}">
      <text class="aux-text">维修师傅：</text>
      <text>{{orderDetail.staffName}}（{{orderDetail.staffPhone}}）</text>
    </view>
    <view class="detail-item" wx:if="{{orderDetail.status === 'processing'}}">
    </view>
  </view>

  <!-- 操作按钮 -->
  <view wx:if="{{!loading}}" class="btn-group">
    <!-- 已分配服务商时显示“联系救援师傅” -->
    <view 
      wx:if="{{(orderDetail.staffPhone || orderDetail.supplierPhone) && orderDetail.status !== 'cancelled' && orderDetail.status !== 'completed'}}"
      class="btn-secondary" 
      bindtap="handleCallPhone"
    >
      联系救援师傅
    </view>

    <!-- 待救援状态显示“取消订单” -->
    <view 
      wx:if="{{orderDetail.status === 'pending'}}"
      class="btn" 
      bindtap="handleCancelOrder" 
      style="background-color: #F53F3F;"
    >
      取消订单
    </view>

        <!-- 导出订单按钮 -->
    <view 
      wx:if="{{orderDetail.status}}"
      class="btn" 
      bindtap="handleExportOrder"
      style="background-color: #1677FF; margin-top: 10px;"
    >
      导出订单信息
    </view>

    <!-- 已完成且未评价时显示“去评价” -->
    <view 
      wx:if="{{orderDetail.status === 'completed' && orderDetail.evaluateStatus === 0}}"
      class="btn" 
      bindtap="openEvaluateModal"
      style="background-color: #07C160;"
    >
      去评价
    </view>

    <!-- 已评价提示 -->
    <view 
      wx:if="{{orderDetail.status === 'completed' && orderDetail.evaluateStatus === 1}}"
      class="btn disabled-btn"
    >
      已评价
    </view>
  </view>

  <!-- 评价弹窗 -->
<view class="modal-mask" wx:if="{{showEvaluate}}" bindtap="closeEvaluateModal"></view>
<view class="modal-content" wx:if="{{showEvaluate}}">
  <view class="modal-header">
    <text class="modal-title">评价订单</text>
    <view class="close-btn" bindtap="closeEvaluateModal">✕</view>
  </view>
  <view class="modal-body">
    <view class="score-section">
      <text>评分：</text>
      <view class="stars">
        <view 
          wx:for="{{[1,2,3,4,5]}}" 
          wx:key="*this" 
          class="star {{item <= evaluateForm.score ? 'active' : ''}}"
          bindtap="handleScoreChange"
          data-score="{{item}}"
        >
          ★
        </view>
      </view>
    </view>
    <view class="content-section">
      <textarea placeholder="请输入评价内容（选填）" value="{{evaluateForm.content}}" bindinput="handleContentInput"></textarea>
    </view>
  </view>
  <view class="modal-footer">
    <button class="confirm-btn" bindtap="submitEvaluate">提交评价</button>
  </view>
</view>
</view>