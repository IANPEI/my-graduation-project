/* 详情项：行布局，左对齐 */
.detail-item {
  display: flex;
  margin: 16rpx 0;
}

.detail-item .aux-text {
  min-width: 120rpx;
  display: inline-block;
}

/* 状态文字 */
.order-status {
  font-size: 28rpx;
  color: #FF7D00;
}

/* 评价弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 12rpx;
  width: 80%;
  max-width: 600rpx;
  z-index: 1000;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between; /* 让标题和关闭按钮左右对齐 */
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.score-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 28rpx;
  color: #333;
}

.stars {
  display: flex; /* 让星星在一行 */
  margin-left: 20rpx;
}

.star {
  font-size: 40rpx;
  color: #ddd;
  margin-right: 20rpx;
  line-height: 1;
}

.star.active {
  color: #FFD21E; /* 选中的星星颜色 */
}

.content-section textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.modal-footer {
  padding: 0 30rpx 30rpx;
}

.confirm-btn {
  width: 100%;
  background-color: #07C160;
  color: #fff;
  border: none;
  padding: 24rpx 0;
  border-radius: 8rpx;
  font-size: 32rpx;
}

/* 联系救援师傅按钮（二级按钮样式） */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f0f4ff;
  color: #1677FF;
  border: 1rpx solid #1677FF;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  margin-top: 20rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

/* 按钮点击态（按下效果） */
.btn-secondary:active {
  background-color: #e6f0ff;
  color: #0f5fcc;
  border-color: #0f5fcc;
}