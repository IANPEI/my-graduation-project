.staff-container {
  padding: 24rpx;
  background: #f6f7fb;
  min-height: 100vh;
}

/* 添加按钮 */
.add-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #409eff, #66b1ff);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* 列表 */
.staff-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 卡片 */
.staff-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

/* 头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 状态 */
.status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;

  display: flex;
  align-items: center;
  justify-content: center;
}

.status text {
  font-size: 24rpx;
  line-height: 1; /* 🔥 关键修复 */
}

.status.online {
  background: #e8f8f0;
  color: #52c41a;
}

.status.offline {
  background: #f2f2f2;
  color: #999;
}

/* 行 */
.card-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label {
  width: 80rpx;
  font-size: 26rpx;
  color: #999;
}

.value {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
}

/* 技能标签 */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background: #ecf5ff;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;

  display: flex;
  align-items: center;
  justify-content: center;
}

.tag text {
  font-size: 24rpx;
  color: #409eff;
  line-height: 1; /* 🔥 关键修复 */
}

/* 操作区 */
.card-actions {
  display: flex;
  margin-top: 20rpx;
  gap: 12rpx;
}

/* 按钮 */
.btn {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 0;
}

/* 编辑 */
.btn.edit {
  background: #ecf5ff;
  color: #409eff;
}

/* 删除 */
.btn.delete {
  background: #fff1f0;
  color: #f53f3f;
}

/* 状态按钮 */
.btn.status-btn.online {
  background: #e8f8f0;
  color: #52c41a;
}

.btn.status-btn.offline {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  margin-top: 200rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 表单 */
.dialog-form {
  padding: 20rpx 0;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
}

.form-input {
  flex: 1;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 12rpx;
}